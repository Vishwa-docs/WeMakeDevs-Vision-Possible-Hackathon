# ============================================================
# WorldLens Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# ----- Stream (Required) -----
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# ----- Google / Gemini (Required for Realtime Voice+Vision) -----
GOOGLE_API_KEY=your_google_api_key_here

# ----- Google Maps (Required for GuideLens Navigation — Day 4) -----
MAPS_API_KEY=your_google_maps_api_key_here

# ----- NVIDIA NGC (Required for Cosmos 2 VLM — Day 3+) -----
NGC_API_KEY=your_nvidia_ngc_api_key_here

# ----- HuggingFace (Required for NLP post-processing — Day 2+) -----
HF_API_TOKEN=your_huggingface_token_here

# ----- xAI / Grok (Optional — VLM fallback provider) -----
XAI_API_KEY=your_xai_api_key_here

# ----- Azure OpenAI (Optional — VLM fallback provider) -----
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ----- Langfuse (Optional — Telemetry & Tracing) -----
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ----- Agent Config -----
AGENT_MODE=guidelens
# Options: "signbridge" | "guidelens"

# ----- M5StickC Camera (Optional — Day 7) -----
M5_CAMERA_URL=rtsp://192.168.1.100:8554/
