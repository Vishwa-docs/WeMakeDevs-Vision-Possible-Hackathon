# ============================================================
# WorldLens Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# ─────────────────────────────────────────────────────────────
# REQUIRED — Core services (app won't work without these)
# ─────────────────────────────────────────────────────────────

# GetStream — WebRTC video/audio transport
# Get yours at: https://getstream.io/dashboard/
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Google Gemini — Realtime voice + vision reasoning engine
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────────────────────
# RECOMMENDED — Enhanced features
# ─────────────────────────────────────────────────────────────

# Google Maps Platform — Navigation directions + nearby search
# Enable: Directions API, Geocoding API, Places API, Geolocation API
# Get yours at: https://console.cloud.google.com/apis/credentials
# Without this key, navigation uses stub/mock directions
MAPS_API_KEY=your_google_maps_api_key_here

# HuggingFace — NLP post-processing (gloss → English for SignBridge)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here

# ─────────────────────────────────────────────────────────────
# OPTIONAL — VLM fallback providers (auto-failover chain)
# ─────────────────────────────────────────────────────────────

# NVIDIA NGC — Cosmos 2 VLM (dense scene descriptions)
# Get yours at: https://org.ngc.nvidia.com/setup/api-key
NGC_API_KEY=your_nvidia_ngc_api_key_here

# xAI Grok — Vision fallback
# Get yours at: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Azure OpenAI — GPT-4o Vision fallback
# Get yours at: https://portal.azure.com/ → Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Observability & Telemetry
# ─────────────────────────────────────────────────────────────

# Langfuse — LLM tracing & analytics
# Get yours at: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─────────────────────────────────────────────────────────────
# CONFIGURATION — Agent behavior
# ─────────────────────────────────────────────────────────────

# Starting agent mode: "signbridge" (sign language) or "guidelens" (env awareness)
AGENT_MODE=guidelens

# ─────────────────────────────────────────────────────────────
# HARDWARE — M5StickC Camera (Day 7)
# ─────────────────────────────────────────────────────────────

# RTSP stream URL from M5StickC Plus camera
M5_CAMERA_URL=rtsp://192.168.1.100:8554/
