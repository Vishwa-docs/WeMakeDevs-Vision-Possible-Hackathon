# ============================================================
# WorldLens Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# ─────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────

# GetStream API key (same value as STREAM_API_KEY in backend/.env)
# Get yours at: https://getstream.io/dashboard/
VITE_STREAM_API_KEY=your_stream_api_key_here

# Backend server URL (default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# OPTIONAL — 3D Avatar
# ─────────────────────────────────────────────────────────────

# Custom 3D avatar .glb URL (used in SignBridge mode)
# NOTE: Ready Player Me was discontinued on Jan 31, 2026.
# Supply your own .glb model with viseme morph targets, or leave empty
# to use the built-in geometric fallback avatar.
VITE_AVATAR_URL=
