# ============================================================
# WorldLens Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# ─────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────

# GetStream API key (same value as STREAM_API_KEY in backend/.env)
# Get yours at: https://getstream.io/dashboard/
VITE_STREAM_API_KEY=your_stream_api_key_here

# Backend server URL (default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# OPTIONAL — 3D Avatar
# ─────────────────────────────────────────────────────────────

# Ready Player Me avatar .glb URL (used in SignBridge mode)
# Create your own at: https://readyplayer.me/
# 1. Create a free account and design your avatar
# 2. Copy the avatar URL (ends with .glb)
# 3. Append morph target params:
#    ?morphTargets=viseme_aa,viseme_E,viseme_I,viseme_O,viseme_U,viseme_PP,viseme_FF,jawOpen&textureAtlas=1024
# Leave empty to use the default avatar
VITE_AVATAR_URL=
